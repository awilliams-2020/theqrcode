    "test:coverage": "jest --coverage",
    "test:coverage:api": "jest --testPathPatterns=api --testEnvironment=node --coverage",
    "test:coverage:components": "jest --testPathPatterns=components --testEnvironment=jsdom --coverage",
    "test:api": "jest --testPathPatterns=api --testEnvironment=node",
