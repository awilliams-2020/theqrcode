    "restaurant-qr-code",
    "real-estate-qr-code",
    "event-qr-code",
    "wifi-qr-code",
    "contact-qr-code",
    "vcard-qr-code",
    "qr-code-saas",
    "qr-code-platform",
    "nextjs",
    "postgresql",
    "prisma",
    "stripe",
    "docker",
    "typescript",
    "analytics",
    "subscription-management",
    "api",
    "webhooks",
    "email-automation"
